{
  "manifest_version": 3,
  "name": "GHL Payload Harvester",
  "version": "1.9.0",
  "description": "Intercepts every GoHighLevel API call (documented or not) and captures full request + response payloads and headers for workflow reverse-engineering and automated deployment.",
  "permissions": [
    "webRequest",
    "storage",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://*.leadconnectorhq.com/*",
    "*://*.gohighlevel.com/*",
    "*://*.msgsndr.com/*",
    "*://*.firebasestorage.googleapis.com/*",
    "*://*.firestore.googleapis.com/*",
    "*://identitytoolkit.googleapis.com/*",
    "*://securetoken.googleapis.com/*",
    "http://127.0.0.1:7777/*",
    "http://localhost:7777/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.gohighlevel.com/*",
        "*://*.leadconnectorhq.com/*",
        "*://*.msgsndr.com/*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": [
        "*://*.gohighlevel.com/*",
        "*://*.leadconnectorhq.com/*",
        "*://*.msgsndr.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GHL Endpoint Harvester",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
